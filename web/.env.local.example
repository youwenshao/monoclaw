# Supabase (Auth uses Google SSO — see web/docs/AUTH_GOOGLE_SSO.md for setup)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (checkout after contract signing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (Native Signing System: verification codes + signed contract email)
RESEND_API_KEY=re_xxx
# Optional: defaults to Native Signing System <contracts@sentimento.tech>
# RESEND_FROM_EMAIL=Native Signing System <noreply@yourdomain.com>
# Optional: BCC for contract-executed emails (default: team@sentimento.dev)
# ADMIN_EMAIL=admin@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APPLE_STORE_MAC_MINI_URL=https://www.apple.com/hk/shop/buy-mac/mac-mini
NEXT_PUBLIC_APPLE_STORE_IMAC_URL=https://www.apple.com/hk/shop/buy-mac/imac
